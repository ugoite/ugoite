#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
PACKAGE_DIR="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"
PACKAGE_JSON="${PACKAGE_DIR}/package.json"
REPO="${UGOITE_GITHUB_REPO:-ugoite/ugoite}"
RAW_BASE_URL="${UGOITE_INSTALL_SCRIPT_BASE_URL:-https://raw.githubusercontent.com/${REPO}}"

log() {
  printf '%s\n' "$*" >&2
}

fail() {
  log "$*"
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "Required command not found: $1"
}

package_version() {
  require_command node
  node -e "process.stdout.write(require(process.argv[1]).version)" "${PACKAGE_JSON}"
}

resolve_script_url() {
  if [ -n "${UGOITE_INSTALL_SCRIPT_URL:-}" ]; then
    printf '%s' "${UGOITE_INSTALL_SCRIPT_URL}"
    return
  fi

  printf '%s/v%s/scripts/install-ugoite-cli.sh' \
    "${RAW_BASE_URL%/}" \
    "$(package_version)"
}

print_help() {
  cat <<'HELP'
Bootstrap the released Ugoite Rust CLI from the public installer package.

Usage:
  ugoite-install
  UGOITE_VERSION=0.1.0 ugoite-install

Environment:
  UGOITE_VERSION                  Exact CLI release to install. Defaults to the package version.
  UGOITE_INSTALL_DIR              Target directory for the downloaded ugoite binary.
  UGOITE_GITHUB_REPO              Override the GitHub repository owner/name.
  UGOITE_DOWNLOAD_BASE_URL        Override the release asset base URL for the downstream installer.
  UGOITE_INSTALL_SCRIPT_BASE_URL  Override the raw script base URL.
  UGOITE_INSTALL_SCRIPT_URL       Override the exact installer script URL.

Special flags:
  --help               Show this help text.
  --print-script-url   Print the resolved raw installer URL and exit.
HELP
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
  --print-script-url)
    resolve_script_url
    printf '\n'
    exit 0
    ;;
esac

require_command bash
require_command curl

resolved_version="$(package_version)"
export UGOITE_VERSION="${UGOITE_VERSION:-${resolved_version}}"

tmpdir="$(mktemp -d)"
cleanup() {
  rm -rf "${tmpdir}"
}
trap cleanup EXIT HUP INT TERM

script_url="$(resolve_script_url)"
script_path="${tmpdir}/install-ugoite-cli.sh"

log "Downloading installer script from ${script_url}"
curl -fsSL "${script_url}" -o "${script_path}"
chmod +x "${script_path}"

bash "${script_path}" "$@"
