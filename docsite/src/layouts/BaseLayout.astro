---
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import DocNavTree from "../components/DocNavTree.astro";
import {
  getNavSectionsWithChildren,
  getNewcomerNavSections,
  topLinks,
} from "../lib/navigation";
import { withBasePath } from "../lib/base-path";
import "../styles.css";

export interface Props {
  title: string;
  description?: string;
  toc?: Array<{ id: string; title: string }>;
  related?: Array<{ href: string; label: string }>;
  fullWidth?: boolean;
  newcomerMode?: boolean;
}

const {
  title,
  description,
  toc = [],
  related = [],
  fullWidth = false,
  newcomerMode = false,
} = Astro.props;
const hasRight = toc.length > 0 || related.length > 0;
const navSections = newcomerMode
  ? getNewcomerNavSections()
  : await getNavSectionsWithChildren();
const searchIndexUrl = withBasePath("/search-index.json");
const subNavByHref = new Map(
  navSections.flatMap((section) => {
    const overview = section.items.find((item) => item.href === section.overviewHref);
    if (!overview) {
      return [];
    }
    const children = section.items.filter(
      (item) => item.href !== section.overviewHref,
    );
    return [[overview.href, section.expandAll ? children : children.slice(0, 5)]];
  }),
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description ?? "Ugoite — local-first knowledge space documentation with resource-first MCP guidance."} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      />
    </noscript>
  </head>
  <body data-search-index-url={searchIndexUrl}>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={withBasePath("/")} class="site-brand">Ugoite</a>
        <nav class="site-nav">
          {topLinks.map((link) => {
            const children = subNavByHref.get(link.href) ?? [];
            return (
              <div class="site-nav-menu">
                <a href={withBasePath(link.href)}>{link.title}</a>
                {children.length > 0 && (
                  <div class="site-nav-submenu">
                    {children.map((item) => (
                      <a href={withBasePath(item.href)}>{item.title}</a>
                    ))}
                  </div>
                )}
              </div>
            );
          })}
        </nav>
        <a href="https://github.com/ugoite/ugoite" class="site-github-link" target="_blank" rel="noreferrer">GitHub</a>
        <div class="site-search">
          <input
            type="search"
            class="site-search-input"
            placeholder="Search docs"
            aria-label="Search docs"
            data-doc-search-input
            autocomplete="off"
          />
          <div class="site-search-results" data-doc-search-results hidden></div>
        </div>
        <button
          type="button"
          class="mobile-nav-toggle"
          data-mobile-nav-open
          aria-controls="mobile-doc-nav"
          aria-expanded="false"
          aria-label="Open navigation"
        >
          <span class="mobile-nav-toggle-icon" aria-hidden="true"></span>
          Menu
        </button>
        <ThemeSwitcher />
      </div>
    </header>

    <div class="mobile-nav-overlay" data-mobile-nav-overlay hidden></div>
    <aside id="mobile-doc-nav" class="mobile-doc-nav" data-mobile-doc-nav aria-hidden="true">
      <div class="mobile-doc-nav-header">
        <span>Navigation</span>
        <button type="button" class="mobile-nav-close" data-mobile-nav-close aria-label="Close navigation">Close</button>
      </div>
      <nav class="mobile-doc-nav-body" aria-label="Mobile documentation navigation">
        <div class="mobile-top-links">
          {topLinks.map((link) => (
            <a href={withBasePath(link.href)} class="doc-sidebar-link">{link.title}</a>
          ))}
          <a href="https://github.com/ugoite/ugoite" class="doc-sidebar-link" target="_blank" rel="noreferrer">GitHub</a>
        </div>
        <DocNavTree navSections={navSections} />
      </nav>
    </aside>

    {fullWidth ? (
      <main class="doc-shell-full">
        <slot />
      </main>
    ) : hasRight ? (
      <main class="doc-shell-3col">
        <div class="doc-shell-main space-y-6">
          <slot />
        </div>
        <aside class="doc-right">
          {toc.length > 0 && (
            <div>
              <div class="doc-toc-title">On this page</div>
              {toc.map((item) => (
                <a href={`#${item.id}`} class="doc-toc-link">{item.title}</a>
              ))}
            </div>
          )}
          {related.length > 0 && (
            <div class="mt-6">
              <div class="doc-toc-title">Related</div>
              {related.map((item) => (
                <a href={withBasePath(item.href)} class="doc-toc-link">{item.label}</a>
              ))}
            </div>
          )}
        </aside>
      </main>
    ) : (
      <main class="doc-shell">
        <div class="doc-shell-main space-y-6">
          <slot />
        </div>
      </main>
    )}

    <footer class="site-footer">
      <div style="max-width: 80rem; margin: 0 auto;">
        Built from source specs. <a href={withBasePath("/docs/spec/index")}>Browse specification</a>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const nav = document.querySelector("[data-mobile-doc-nav]");
        const overlay = document.querySelector("[data-mobile-nav-overlay]");
        const openButton = document.querySelector("[data-mobile-nav-open]");
        const closeButton = document.querySelector("[data-mobile-nav-close]");
        const searchInput = document.querySelector("[data-doc-search-input]");
        const searchResults = document.querySelector("[data-doc-search-results]");
        const searchIndexUrl = document.body.dataset.searchIndexUrl ?? "/search-index.json";

        if (!nav || !overlay || !openButton || !closeButton) {
          return;
        }

        const setOpen = (isOpen) => {
          nav.classList.toggle("is-open", isOpen);
          nav.setAttribute("aria-hidden", String(!isOpen));
          openButton.setAttribute("aria-expanded", String(isOpen));
          overlay.toggleAttribute("hidden", !isOpen);
          document.body.classList.toggle("mobile-nav-open", isOpen);
        };

        openButton.addEventListener("click", () => setOpen(true));
        closeButton.addEventListener("click", () => setOpen(false));
        overlay.addEventListener("click", () => setOpen(false));
        nav.addEventListener("click", (event) => {
          const target = event.target;
          if (target instanceof HTMLAnchorElement) {
            setOpen(false);
          }
        });
        window.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && nav.classList.contains("is-open")) {
            setOpen(false);
          }
        });

        if (searchInput instanceof HTMLInputElement && searchResults instanceof HTMLDivElement) {
          let searchIndex = [];
          let searchLoaded = false;

          const renderResults = (query, results) => {
            if (query.length < 2 || results.length === 0) {
              searchResults.hidden = true;
              searchResults.innerHTML = "";
              return;
            }

            searchResults.hidden = false;
            searchResults.innerHTML = results
              .slice(0, 8)
              .map((item) => {
                const snippet = item.content ? item.content.slice(0, 140) : "";
                return `<a class="site-search-result" href="${item.href}"><span class="site-search-result-title">${item.title}</span>${snippet ? `<span class=\"site-search-result-snippet\">${snippet}</span>` : ""}</a>`;
              })
              .join("");
          };

          const loadSearchIndex = async () => {
            if (searchLoaded) return;
            const response = await fetch(searchIndexUrl);
            if (!response.ok) return;
            searchIndex = await response.json();
            searchLoaded = true;
          };

          searchInput.addEventListener("input", async () => {
            const query = searchInput.value.trim().toLowerCase();
            if (query.length < 2) {
              renderResults(query, []);
              return;
            }
            await loadSearchIndex();
            const queryTerms = query.split(/\s+/).filter(Boolean);
            const matches = searchIndex.filter((item) => {
              const haystack = `${item.title} ${item.content}`.toLowerCase();
              return queryTerms.every((term) => haystack.includes(term));
            });
            renderResults(query, matches);
          });

          document.addEventListener("click", (event) => {
            const target = event.target;
            if (
              target instanceof Node &&
              !searchResults.contains(target) &&
              target !== searchInput
            ) {
              searchResults.hidden = true;
            }
          });
        }
      })();
    </script>
  </body>
</html>
